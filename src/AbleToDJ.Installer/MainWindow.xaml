<Window x:Class="AbleToDJ.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AbleToDJ v1.0.0 — Instalação" 
        Icon="pack://application:,,,/AbleToDJ_Installer;component/Resources/icon.png"
        Width="550" Height="380"
        Background="#0a0a0c"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        BorderThickness="1"
        BorderBrush="#33ffffff">
    <Window.Resources>
        <LinearGradientBrush x:Key="purpleGrad" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#ffaa44" Offset="0.0"/>
            <GradientStop Color="#fc5c7d" Offset="1.0"/>
        </LinearGradientBrush>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#17181c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#44ffffff"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#22242b"/>
                    <Setter Property="BorderBrush" Value="#88ffffff"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5,0,15" MouseDown="Header_MouseDown">
            <Image Source="pack://application:,,,/AbleToDJ_Installer;component/Resources/icon.png" Width="40" Height="40" Margin="0,0,15,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="AbleToDJ v1.0.0" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Pioneer DDJ-400 Ableton Bridge Installer" FontSize="11" Foreground="#88ffffff"/>
            </StackPanel>
        </StackPanel>

        <!-- Main Body -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <!-- Initial screen -->
            <StackPanel x:Name="WelcomePanel" VerticalAlignment="Center">
                <TextBlock Text="Bem-vindo ao assistente de instalação do AbleToDJ!" FontSize="14" Foreground="White" Margin="0,0,0,10"/>
                <TextBlock Text="Este utilitário irá instalar a aplicação ponte AbleToDJ na sua pasta de programas local e configurar automaticamente os scripts de controle remoto MIDI no diretório do Ableton Live." 
                           TextWrapping="Wrap" FontSize="12" Foreground="#bbffffff" LineHeight="18" Margin="0,0,0,20"/>
                <TextBlock Text="Requisitos: Ableton Live (10/11/12) e loopMIDI já instalados." FontSize="11" Foreground="#ffffaa44"/>
            </StackPanel>

            <!-- Install screen (hidden initially) -->
            <StackPanel x:Name="InstallPanel" Visibility="Collapsed" VerticalAlignment="Center">
                <TextBlock x:Name="StatusTitle" Text="Instalando componentes..." FontSize="13" Foreground="White" Margin="0,0,0,10"/>
                <ProgressBar x:Name="InstallProgress" Height="15" Maximum="100" Value="0" Background="#11ffffff" Foreground="{StaticResource purpleGrad}" BorderThickness="0"/>
                <ScrollViewer Height="100" Margin="0,15,0,0" VerticalScrollBarVisibility="Auto" Background="#060608" BorderBrush="#22ffffff" BorderThickness="1">
                    <TextBlock x:Name="LogText" Text="" Margin="8" FontSize="10" FontFamily="Consolas" Foreground="#aaffffff" TextWrapping="Wrap"/>
                </ScrollViewer>
                <CheckBox x:Name="LaunchCheckBox" Content="Iniciar o AbleToDJ após concluir" Foreground="White" Margin="0,12,0,0" FontSize="11" Visibility="Collapsed" IsChecked="True"/>
            </StackPanel>
        </Grid>

        <!-- Footer Buttons -->
        <DockPanel Grid.Row="2" LastChildFill="False">
            <Button x:Name="CancelButton" Content="Cancelar" Style="{StaticResource ModernButton}" Click="Cancel_Click" DockPanel.Dock="Right" Margin="10,0,0,0"/>
            <Button x:Name="InstallButton" Content="Instalar Agora" Style="{StaticResource ModernButton}" Background="{StaticResource purpleGrad}" BorderThickness="0" Click="Install_Click" DockPanel.Dock="Right"/>
        </DockPanel>
    </Grid>
</Window>
