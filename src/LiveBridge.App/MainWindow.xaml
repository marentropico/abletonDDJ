<Window x:Class="LiveBridge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pioneer DJ DDJ-400 — Réplica Visual Nativa" 
        Width="1200" Height="800"
        Background="#08080a"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DropShadowEffect x:Key="infoShadow" BlurRadius="30" Color="Black" Opacity="0.6"/>
        
        <LinearGradientBrush x:Key="bodyGrad" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#2c2d30" Offset="0.0"/>
            <GradientStop Color="#17181a" Offset="1.0"/>
        </LinearGradientBrush>
        <RadialGradientBrush x:Key="knobBase" Center="0.35,0.3" GradientOrigin="0.35,0.3" RadiusX="0.75" RadiusY="0.75">
            <GradientStop Color="#4a4b4e" Offset="0.0"/>
            <GradientStop Color="#101112" Offset="1.0"/>
        </RadialGradientBrush>
        <RadialGradientBrush x:Key="knobFace" Center="0.35,0.3" GradientOrigin="0.35,0.3" RadiusX="0.75" RadiusY="0.75">
            <GradientStop Color="#3a3b3e" Offset="0.0"/>
            <GradientStop Color="#0c0d0e" Offset="1.0"/>
        </RadialGradientBrush>
        <LinearGradientBrush x:Key="btnGrad" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#3c3d40" Offset="0.0"/>
            <GradientStop Color="#1c1d1f" Offset="1.0"/>
        </LinearGradientBrush>
        <RadialGradientBrush x:Key="btnRoundGrad" Center="0.35,0.3" GradientOrigin="0.35,0.3" RadiusX="0.75" RadiusY="0.75">
            <GradientStop Color="#45464a" Offset="0.0"/>
            <GradientStop Color="#141516" Offset="1.0"/>
