        <LinearGradientBrush x:Key="orangeGrad" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#ffb347" Offset="0.0"/>
            <GradientStop Color="#e07800" Offset="1.0"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="blueGrad" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#5bc2ff" Offset="0.0"/>
            <GradientStop Color="#1c7fc4" Offset="1.0"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="padGrad" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#3a2225" Offset="0.0"/>
            <GradientStop Color="#1a1011" Offset="1.0"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="purpleGrad" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#e080ff" Offset="0.0"/>
            <GradientStop Color="#a000e0" Offset="1.0"/>
