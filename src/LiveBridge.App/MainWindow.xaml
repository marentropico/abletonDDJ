        <TextBlock Canvas.Left="1340.0" Canvas.Top="570" Width="300" TextAlignment="Center" FontSize="8" Text="SAMPLER" Foreground="#d8dade" FontFamily="Arial"/>
        <Canvas x:Name="SamplerMode_Right" Cursor="Hand" Background="Transparent" MouseLeftButtonDown="Element_MouseLeftButtonDown" MouseEnter="Element_MouseEnter" MouseLeave="Element_MouseLeave" Tag="MODO SAMPLER (Deck 2) — SHIFT: KEY SHIFT — seleciona o modo dos pads">
            <Rectangle Canvas.Left="1469" Canvas.Top="582" Width="42" Height="10" RadiusX="2" RadiusY="2" Fill="{StaticResource btnGrad}" Stroke="#050505" StrokeThickness="1"/>
        </Canvas>
        <TextBlock Canvas.Left="1340.0" Canvas.Top="595" Width="300" TextAlignment="Center" FontSize="6.5" Text="KEY SHIFT" Foreground="#ff9f1c" FontFamily="Arial"/>
        <Canvas x:Name="Pad4_Right" Cursor="Hand" Background="Transparent" MouseLeftButtonDown="Element_MouseLeftButtonDown" MouseEnter="Element_MouseEnter" MouseLeave="Element_MouseLeave" Tag="SAMPLER (Deck 2) — SHIFT: KEY SHIFT — pad de performance, linha 1">
            <Rectangle Canvas.Left="1457" Canvas.Top="610" Width="66" Height="42" RadiusX="6" RadiusY="6" Fill="{StaticResource padGrad}" Stroke="Black" StrokeThickness="1"/>
        </Canvas>
        <Canvas x:Name="Pad8_Right" Cursor="Hand" Background="Transparent" MouseLeftButtonDown="Element_MouseLeftButtonDown" MouseEnter="Element_MouseEnter" MouseLeave="Element_MouseLeave" Tag="SAMPLER (Deck 2) — SHIFT: KEY SHIFT — pad de performance, linha 2">
            <Rectangle Canvas.Left="1457" Canvas.Top="660" Width="66" Height="42" RadiusX="6" RadiusY="6" Fill="{StaticResource padGrad}" Stroke="Black" StrokeThickness="1"/>
        </Canvas>
        <Canvas x:Name="TempoSlider_Right" Cursor="Hand" Background="Transparent" MouseLeftButtonDown="Element_MouseLeftButtonDown" MouseEnter="Element_MouseEnter" MouseLeave="Element_MouseLeave" Tag="TEMPO (Deck 2) — ajusta a velocidade de reprodução (pitch)">
            <Rectangle Canvas.Left="1565" Canvas.Top="428" Width="12" Height="292" RadiusX="3" RadiusY="3" Fill="#101012" Stroke="Black" StrokeThickness="1"/>
            <Rectangle Canvas.Left="1557" Canvas.Top="547.7" Width="28" Height="26" RadiusX="3" RadiusY="3" Fill="{StaticResource capGrad}" Stroke="#050505" StrokeThickness="1"/>
            <Line X1="1557" Y1="560.7" X2="1585" Y2="560.7" Stroke="#050505" StrokeThickness="1.5"/>
        </Canvas>
        <TextBlock Canvas.Left="1422.0" Canvas.Top="730.35" Width="300" TextAlignment="Center" FontSize="9" Text="TEMPO" Foreground="#d8dade" FontFamily="Arial"/>
        <TextBlock Canvas.Left="1422.0" Canvas.Top="411.5" Width="300" TextAlignment="Center" FontSize="10" Text="−" Foreground="#d8dade" FontFamily="Arial"/>
        <TextBlock Canvas.Left="1422.0" Canvas.Top="724.5" Width="300" TextAlignment="Center" FontSize="10" Text="+" Foreground="#d8dade" FontFamily="Arial"/>
            </Canvas>
        </Viewbox>
        
        <!-- Console de logs na parte inferior -->
        <Border Height="40" VerticalAlignment="Bottom" Background="#EA0F172A" BorderBrush="#25FFFFFF" BorderThickness="0,1,0,0">
            <TextBlock x:Name="LogConsole" Text="Aguardando conexão MIDI..." Foreground="#38bdf8" 
                       FontFamily="Consolas" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Painel de Detalhes Flutuante (Glassmorphism simulado com Background escuro semi-transparente) -->
        <Border x:Name="InfoPanel" 
                Width="320" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Margin="0,20,20,80" Background="#EA121218" CornerRadius="16"
                BorderBrush="#25FFFFFF" BorderThickness="1"
                Visibility="Collapsed" Effect="{StaticResource infoShadow}"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Cabeçalho -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock x:Name="InfoTitle" Text="Nenhum Controle" FontSize="16" FontWeight="Bold" Foreground="#38bdf8" TextWrapping="Wrap" Margin="0,0,30,0"/>
                    <Button x:Name="BtnClose" Content="×" FontSize="24" Foreground="#94a3b8" Background="Transparent" BorderBrush="Transparent" 
                            HorizontalAlignment="Right" VerticalAlignment="Top" Width="24" Height="24" Click="BtnClose_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
                
                <!-- Corpo -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Ação Ableton -->
                        <TextBlock Text="AÇÃO NO ABLETON LIVE" FontSize="10" FontWeight="Bold" Foreground="#64748b" Margin="0,0,0,6"/>
                        <TextBlock x:Name="InfoDesc" Text="Detalhes do mapeamento" FontSize="13" Foreground="#cbd5e1" TextWrapping="Wrap" Margin="0,0,0,16"/>
                        
                        <!-- Ação Shift -->
                        <TextBlock Text="COM SHIFT PRESSIONADO" FontSize="10" FontWeight="Bold" Foreground="#64748b" Margin="0,0,0,6"/>
                        <TextBlock x:Name="InfoShift" Text="Detalhes com shift" FontSize="13" Foreground="#cbd5e1" TextWrapping="Wrap" Margin="0,0,0,16"/>
                        
                        <!-- MIDI brutos -->
                        <TextBlock Text="DETALHES MIDI (HARDWARE)" FontSize="10" FontWeight="Bold" Foreground="#64748b" Margin="0,0,0,6"/>
                        <Border Background="#05FFFFFF" CornerRadius="8" BorderBrush="#08FFFFFF" BorderThickness="1" Padding="12">
                            <StackPanel>
                                <TextBlock x:Name="MidiStatus" Text="Status: -" FontSize="12.5" Foreground="#94a3b8" Margin="0,0,0,4"/>
                                <TextBlock x:Name="MidiCc" Text="Data1 (CC): -" FontSize="12.5" Foreground="#94a3b8" Margin="0,0,0,4"/>
                                <TextBlock x:Name="MidiType" Text="Tipo: -" FontSize="12.5" Foreground="#94a3b8"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
